# Local SQLite by default; point at a Turso libSQL URL for production.
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# Solana RPC endpoint used to build (unsigned) transactions server-side.
# Point at a local validator, devnet, or mainnet-beta as needed.
SOLANA_RPC_URL=http://127.0.0.1:8899

# Fee-payer keypair for gasless/sponsored checkout (see README's "Gasless
# checkout" section). JSON array secret key, same format solana-keygen
# writes. Optional - sponsored checkout just 404s without it. For real
# production use this should be a KMS/Kora-backed signer, not a raw key
# in an env var.
RELAYER_SECRET_KEY=

# Gates /api/webhooks/poll and /api/subscriptions/poll behind
# `Authorization: Bearer <this value>` - Vercel Cron sends this header
# automatically when CRON_SECRET is set. Optional - both endpoints stay
# open (dev-friendly) if this isn't set, so set it before exposing them
# publicly.
CRON_SECRET=
